rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users can read all files
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Chat files (images, docs, audio)
    match /chat-files/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024; // 20 MB
    }
    match /chat-images/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024; // 10 MB
    }
    match /chat-audio/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024; // 10 MB
    }

    // Task attachments
    match /task-attachments/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }

    // Proof / evidence uploads (all proof-type folders)
    match /proofs/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    match /financial-proofs/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    match /settlement-proofs/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }

    // Profile avatars
    match /avatars/{userId}/{fileId} {
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024; // 2 MB
    }

    // Announcement attachments
    match /announcements/{fileId} {
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
